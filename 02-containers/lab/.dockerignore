# Drop a copy of this in every service folder under platform/services/.
# Anything in here is excluded from the build context the Docker
# daemon sees. Smaller context = faster builds, fewer accidents.

# vcs
.git
.gitignore
.dockerignore

# editor
.vscode
.idea
*.swp

# go
vendor/
bin/
*.test
*.out
coverage.out

# os
.DS_Store
Thumbs.db

# env
.env
.env.*
!.env.example

# docs we do not need in the image
README.md
*.md
docs/
