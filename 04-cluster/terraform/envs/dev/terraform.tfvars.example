# Copy to terraform.tfvars and edit. terraform.tfvars is gitignored at the repo root.

region          = "eu-west-2"
cluster_name    = "eks-accel-dev"
cluster_version = "1.34" # project floor is 1.33, but it is leaving standard support. Use a current version.

# From EP3: cd ../../../../03-networking/terraform/envs/dev && terraform output private_subnet_ids
private_subnet_ids = ["subnet-aaaa", "subnet-bbbb", "subnet-cccc"]

# Your own IP, from `curl -s ifconfig.me`. Never 0.0.0.0/0.
public_access_cidrs = ["203.0.113.10/32"]

# Your own identity, from `aws sts get-caller-identity`. Required. The module
# does not grant the cluster creator implicit admin, so this is the only thing
# that lets you run kubectl. Get it wrong and you build a cluster you cannot reach
# (recoverable: fix the ARN and apply again).
admin_principal_arns = ["arn:aws:iam::111122223333:role/your-sso-role"]
