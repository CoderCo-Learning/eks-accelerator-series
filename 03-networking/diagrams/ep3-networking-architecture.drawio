<mxfile host="app.diagrams.net" agent="coderco-eks-accelerator" type="device"><diagram name="EP3 - VPC network architecture" id="EP3p1"><mxGraphModel dx="1400" dy="900" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1520" pageHeight="800" math="0" shadow="0"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="t1" value="EP3: VPC and network design" style="text;html=1;align=left;verticalAlign=middle;fontColor=#232F3E;fontSize=20;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="40" y="21" width="900" height="28" as="geometry"/></mxCell><mxCell id="t2" value="Two tiers, three AZs. Nodes and pods sit private. Only the NLB and NAT sit public." style="text;html=1;align=left;verticalAlign=middle;fontColor=#5A6B7B;fontSize=11;fontStyle=0;" vertex="1" parent="1"><mxGeometry x="40" y="50" width="900" height="28" as="geometry"/></mxCell><mxCell id="net" value="Internet" style="rounded=1;arcSize=6;whiteSpace=wrap;html=1;fillColor=#ECEFF1;strokeColor=#607D8B;fontColor=#232F3E;fontSize=12;fontStyle=1;strokeWidth=1.6;dashed=0;verticalAlign=middle;align=center;" vertex="1" parent="1"><mxGeometry x="40" y="95" width="170" height="64" as="geometry"/></mxCell><mxCell id="igw" value="Internet
