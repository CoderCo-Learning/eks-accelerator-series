<mxfile host="app.diagrams.net" agent="coderco-eks-accelerator" type="device"><diagram name="EP3 - VPC network architecture" id="EP3_p1"><mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1700" pageHeight="1200" math="0" shadow="0"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="t1" value="EP3: VPC and network design" style="text;html=1;align=left;verticalAlign=middle;fontColor=#232F3E;fontSize=20;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="40" y="20" width="900" height="30" as="geometry"/></mxCell><mxCell id="t2" value="Two tiers, three AZs, six subnets. Nodes and pods sit private. Only the NLB and NAT sit public. Built today, the cluster goes in EP4." style="text;html=1;align=left;verticalAlign=middle;fontColor=#5A6B7B;fontSize=12;fontStyle=0;" vertex="1" parent="1"><mxGeometry x="40" y="52" width="1080" height="24" as="geometry"/></mxCell><mxCell id="lg" value="How to read this&amp;#10;&amp;#10;Green  = ingress, customer traffic in&amp;#10;Red dashed  = egress to the internet via NAT (see page 2)&amp;#10;Orange dashed  = EKS control plane, AWS-managed, reaches in via ENIs&amp;#10;Purple  = private AWS APIs via VPC endpoints, never the internet" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#B0BEC5;fontColor=#232F3E;fontSize=11;fontStyle=0;dashed=0;align=left;spacingLeft=6;shadow=0;" vertex="1" parent="1"><mxGeometry x="1150" y="18" width="420" height="150" as="geometry"/></mxCell><mxCell id="usr" value="Users /&amp;#10;Internet" style="sketch=0;outlineConnect=0;html=1;fontSize=11;fontStyle=0;aspect=fixed;shadow=0;dashed=0;fillColor=#232F3E;strokeColor=#ffffff;verticalLabelPosition=bottom;verticalAlign=top;align=center;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.users;" vertex="1" parent="1"><mxGeometry x="50" y="150" width="78" height="78" as="geometry"/></mxCell><mxCell id="aws" value="AWS Cloud  (eu-west-2 / London)" style="outlineConnect=0;gradientColor=none;html=1;whiteSpace=wrap;fillColor=none;strokeColor=#232F3E;dashed=0;verticalAlign=top;align=left;spacingLeft=30;fontColor=#232F3E;fontSize=12;fontStyle=1;container=0;collapsible=0;shape=mxgraph.aws4.group;grIcon=mxgraph.aws4.group_aws_cloud_alt;" vertex="1" parent="1"><mxGeometry x="40" y="250" width="1530" height="910" as="geometry"/></mxCell><mxCell id="cp" value="EKS control plane   (AWS-managed account, not in your VPC)&amp;#10;API server + etcd. Reaches into your private subnets through ENIs." style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#FBE9E7;strokeColor=#D86613;fontColor=#232F3E;fontSize=11;fontStyle=1;dashed=0;align=center;spacingLeft=0;shadow=0;" vertex="1" parent="1"><mxGeometry x="1150" y="288" width="400" height="84" as="geometry"/></mxCell><mxCell id="cpi" value="" style="sketch=0;outlineConnect=0;html=1;fontSize=11;fontStyle=0;aspect=fixed;shadow=0;dashed=0;fillColor=#D86613;strokeColor=#ffffff;verticalLabelPosition=bottom;verticalAlign=top;align=center;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.elastic_kubernetes_service;" vertex="1" parent="1"><mxGeometry x="1158" y="296" width="46" height="46" as="geometry"/></mxCell><mxCell id="vpc" value="VPC   10.0.0.0/16   (~65k addresses, built today)" style="outlineConnect=0;gradientColor=none;html=1;whiteSpace=wrap;fillColor=none;strokeColor=#8C4FFF;dashed=0;verticalAlign=top;align=left;spacingLeft=30;fontColor=#8C4FFF;fontSize=12;fontStyle=1;container=0;collapsible=0;shape=mxgraph.aws4.group;grIcon=mxgraph.aws4.group_vpc;" vertex="1" parent="1"><mxGeometry x="70" y="392" width="1460" height="752" as="geometry"/></mxCell><mxCell id="rt" value="Public route table:  0.0.0.0/0 -&amp;gt; IGW&amp;#10;Private route table:  0.0.0.0/0 -&amp;gt; NAT,  S3 prefix -&amp;gt; gateway endpoint" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFF8E1;strokeColor=#FBC02D;fontColor=#5F4B00;fontSize=10;fontStyle=0;dashed=0;align=left;spacingLeft=6;shadow=0;" vertex="1" parent="1"><mxGeometry x="90" y="415" width="360" height="70" as="geometry"/></mxCell><mxCell id="igw" value="Internet&amp;#10;Gateway" style="sketch=0;outlineConnect=0;html=1;fontSize=11;fontStyle=0;aspect=fixed;shadow=0;dashed=0;fillColor=#8C4FFF;strokeColor=#ffffff;verticalLabelPosition=bottom;verticalAlign=top;align=center;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.internet_gateway;" vertex="1" parent="1"><mxGeometry x="770" y="415" width="56" height="56" as="geometry"/></mxCell><mxCell id="nlb" value="NLB  (layer 4)&amp;#10;fronts Traefik ingress" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#7AA116;fontColor=#232F3E;fontSize=11;fontStyle=1;dashed=0;align=center;spacingLeft=0;shadow=0;" vertex="1" parent="1"><mxGeometry x="730" y="510" width="180" height="54" as="geometry"/></mxCell><mxCell id="nlbi" value="" style="sketch=0;outlineConnect=0;html=1;fontSize=11;fontStyle=0;aspect=fixed;shadow=0;dashed=0;fillColor=#7AA116;strokeColor=#ffffff;verticalLabelPosition=bottom;verticalAlign=top;align=center;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.network_load_balancer;" vertex="1" parent="1"><mxGeometry x="738" y="516" width="40" height="40" as="geometry"/></mxCell><mxCell id="aza" value="Availability Zone  eu-west-2a" style="outlineConnect=0;gradientColor=none;html=1;whiteSpace=wrap;fillColor=none;strokeColor=#00A4A6;dashed=1;verticalAlign=top;align=left;spacingLeft=30;fontColor=#00A4A6;fontSize=12;fontStyle=1;container=0;collapsible=0;shape=mxgraph.aws4.group;grIcon=mxgraph.aws4.group_az;" vertex="1" parent="1"><mxGeometry x="100" y="600" width="460" height="440" as="geometry"/></mxCell><mxCell id="puba" value="Public subnet  10.0.96.0/24  (/24, small)" style="outlineConnect=0;gradientColor=none;html=1;whiteSpace=wrap;fillColor=none;strokeColor=#7AA116;dashed=0;verticalAlign=top;align=left;spacingLeft=30;fontColor=#7AA116;fontSize=12;fontStyle=1;container=0;collapsible=0;shape=mxgraph.aw