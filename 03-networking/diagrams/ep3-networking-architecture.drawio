endpoint (FREE)" style="rounded=1;arcSize=6;whiteSpace=wrap;html=1;fillColor=#EDE7F6;strokeColor=#8C4FFF;fontColor=#5e35b1;fontSize=10;fontStyle=1;strokeWidth=1.6;dashed=0;verticalAlign=middle;align=center;" vertex="1" parent="1"><mxGeometry x="465" y="195" width="170" height="80" as="geometry"/></mxCell><mxCell id="ife" value="Interface endpoints
ECR, STS, SSM,
Secrets, CW Logs" style="rounded=1;arcSize=6;whiteSpace=wrap;html=1;fillColor=#EDE7F6;strokeColor=#8C4FFF;fontColor=#5e35b1;fontSize=10;fontStyle=1;strokeWidth=1.6;dashed=0;verticalAlign=middle;align=center;" vertex="1" parent="1"><mxGeometry x="660" y="195" width="190" height="80" as="geometry"/></mxCell><mxCell id="apis" value="AWS service APIs
S3, ECR, STS,
