(API server reaches in)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FBE9E7;strokeColor=#D86613;fontColor=#8a4b1f;fontSize=11;dashed=1;fontStyle=0;arcSize=8;align=center;" vertex="1" parent="1"><mxGeometry x="1400" y="705" width="160" height="50" as="geometry"/></mxCell><mxCell id="c39" value="Tags: internal-elb = 1  •  kubernetes.io/cluster/&lt;name&gt; = shared" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFF8E1;strokeColor=#FBC02D;fontColor=#5F4B00;fontSize=10;align=left;spacingLeft=6;shadow=0;" vertex="1" parent="1"><mxGeometry x="1180" y="815" width="380" height="30" as="geometry"/></mxCell><mxCell id="c40" value="Interface VPC endpoint ENIs live here  (ECR API+DKR, STS, SSM, Secrets Mgr, CW Logs)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE7F6;strokeColor=#8C4FFF;fontColor=#5e35b1;fontSize=11;dashed=0;fontStyle=0;arcSize=8;align=center;" vertex="1" parent="1"><mxGeometry x="1180" y="855" width="380" height="60" as="geometry"/></mxCell><mxCell id="c41" value="S3 Gateway VPC endpoint (FREE, route-table entry)  -  ECR image layers live in S3, so this carries the heaviest pull" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE7F6;strokeColor=#8C4FFF;fontColor=#5e35b1;fontSize=11;dashed=0;fontStyle=1;arcSize=8;align=center;" vertex="1" parent="1"><mxGeometry x="70" y="980" width="1550" height="56" as="geometry"/></mxCell><mxCell id="c42" value="" style="sketch=0;points=[[0,0,0],[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0,0],[0,1,0],[0.25,1,0],[0.5,1,0],[0.75,1,0],[1,1,0],[0,0.25,0],[0,0.5,0],[0,0.75,0],[1,0.25,0],[1,0.5,0],[1,0.75,0]];outlineConnect=0;html=1;fontSize=11;fontStyle=0;aspect=fixed;shadow=0;dashed=0;fillColor=#7AA116;strokeColor=#ffffff;verticalLabelPosition=bottom;verticalAlign=top;align=center;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.simple_storage_service;" vertex="1" parent="1"><mxGeometry x="80" y="986" width="44" height="44" as="geometry"/></mxCell><mxCell id="c43" value="Public route table:  0.0.0.0/0 -&gt; IGW
Private route table:  0.0.0.0/0 -&gt; NAT,  S3 prefix -&gt; gateway endpoint" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFF8E1;strokeColor=#FBC02D;fontColor=#5F4B00;fontSize=10;align=left;spacingLeft=6;shadow=0;" vertex="1" parent="1"><mxGeometry x="1300" y="390" width="320" height="70" as="geometry"/></mxCell><mxCell id="c44" value="ingress" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;fontSize=10;fontColor=#37474F;labelBackgroundColor=#ffffff;strokeWidth=1.6;strokeColor=#2E7D32;" edge="1" parent="1" source="c3" target="c8"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="c45" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;fontSize=10;fontColor=#37474F;labelBackgroundColor=#ffffff;strokeWidth=1.6;strokeColor=#2E7D32;" edge="1" parent="1" source="c8" target="c9"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="c46" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;fontSize=10;fontColor=#37474F;labelBackgroundColor=#ffffff;strokeWidth=1.6;strokeColor=#2E7D32;dashed=0;" edge="1" parent="1" source="c9" target="c16"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="c47" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;fontSize=10;fontColor=#37474F;labelBackgroundColor=#ffffff;strokeWidth=1.6;strokeColor=#2E7D32;dashed=0;" edge="1" parent="1" source="c9" target="c26"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="c48" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;fontSize=10;fontColor=#37474F;labelBackgroundColor=#ffffff;strokeWidth=1.6;strokeColor=#2E7D32;dashed=0;" edge="1" parent="1" source="c9" target="c36"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="c49" value="0.0.0.0/0" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;fontSize=10;fontColor=#37474F;labelBackgroundColor=#ffffff;strokeWidth=1.6;strokeColor=#C62828;dashed=1;" edge="1" parent="1" source="c16" target="c14"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="c50" value="0.0.0.0/0" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;fontSize=10;fontColor=#37474F;labelBackgroundColor=#ffffff;strokeWidth=1.6;strokeColor=#C62828;dashed=1;" edge="1" parent="1" source="c26" target="c14"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="c51" value="0.0.0.0/0" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;fontSize=10;fontColor=#37474F;labelBackgroundColor=#ffffff;strokeWidth=1.6;strokeColor=#C62828;dashed=1;" edge="1" parent="1" source="c36" target="c14"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="c52" value="egress (third-party)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;fontSize=10;fontColor=#37474F;labelBackgroundColor=#ffffff;strokeWidth=1.6;strokeColor=#C62828;" edge="1" parent="1" source="c14" target="c8"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="c53" value="private API via ENIs" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;fontSize=10;fontColor=#37474F;labelBackgroundColor=#ffffff;strokeWidth=1.6;strokeColor=#D86613;dashed=1;endArrow=open;startArrow=open;" edge="1" parent="1" source="c4" target="c36"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="c54" value="AWS APIs (private)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;fontSize=10;fontColor=#37474F;labelBackgroundColor=#ffffff;strokeWidth=1.6;strokeColor=#6A1B9A;dashed=1;" edge="1" parent="1" source="c16" target="c41"><mxGeometry relative="1" as="geometry"/></mxCell></root></mxGraphModel></diagram><diagram name="EP3 - Egress: NAT vs VPC endpoints" id="EP3_-_Egress:_NAT_vs_VPC_endpoints"><mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1700" pageHeight="1100" math="0" shadow="0"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="c1" value="EP3: The egress decision  (the line that earns the mark)" style="text;html=1;align=left;verticalAlign=middle;fontColor=#232F3E;fontSize=20;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="40" y="20" width="900" height="34" as="geometry"/></mxCell><mxCell id="c2" value="Two different things leave the VPC and they take different roads. This is where cost, availability and privacy pull against each other." style="text;html=1;align=left;verticalAlign=middle;fontColor=#5A6B7B;fontSize=12;" vertex="1" parent="1"><mxGeometry x="40" y="54" width="1000" height="24" as="geometry"/></mxCell><mxCell id="c3" value="Pod in a private subnet
(needs to reach something
outside the VPC)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E0F7FA;strokeColor=#00A4A6;fontColor=#232F3E;fontSize=11;dashed=0;fontStyle=1;arcSize=8;align=center;" vertex="1" parent="1"><mxGeometry x="120" y="320" width="220" height="110" as="geometry"/></mxCell><mxCell id="c4" value="" style="sketch=0;points=[[0,0,0],[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0,0],[0,1,0],[0.25,1,0],[0.5,1,0],[0.75,1,0],[1,1,0],[0,0.25,0],[0,0.5,0],[0,0.75,0],[1,0.25,0],[1,0.5,0],[1,0.75,0]];outlineConnect=0;html=1;fontSize=11;fontStyle=0;aspect=fixed;shadow=0;dashed=0;fillColor=#E7157B;strokeColor=#ffffff;verticalLabelPosition=bottom;verticalAlign=top;align=center;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.ec2;" vertex="1" parent="1"><mxGeometry x="128" y="328" width="40" height="40" as="geometry"/></mxCell><mxCell id="c5" value="VPC Endpoints  (PrivateLink)
Stays on the AWS backbone, never the internet" style="points=[[0,0],[0.25,0],[0.5,0],[0.75,0],[1,0],[1,0.25],[1,0.5],[1,0.75],[1,1],[0.75,1],[0.5,1],[0.25,1],[0,1],[0,0.75],[0,0.5],[0,0.25]];outlineConnect=0;gradientColor=none;html=1;whiteSpace=wrap;fillColor=none;strokeColor=#8C4FFF;dashed=1;verticalAlign=top;align=left;spacingLeft=30;fontColor=#8C4FFF;fontSize=12;fontStyle=1;container=0;collapsible=0;shape=mxgraph.aws4.group;grIcon=mxgraph.aws4.group_security_group;" vertex="1" parent="1"><mxGeometry x="560" y="150" width="360" height="150" as="geometry"/></mxCell><mxCell id="c6" value="" style="sketch=0;points=[[0,0,0],[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0,0],[0,1,0],[0.25,1,0],[0.5,1,0],[0.75,1,0],[1,1,0],[0,0.25,0],[0,0.5,0],[0,0.75,0],[1,0.25,0],[1,0.5,0],[1,0.75,0]];outlineConnect=0;html=1;fontSize=11;fontStyle=0;aspect=fixed;shadow=0;dashed=0;fillColor=#7AA116;strokeColor=#ffffff;verticalLabelPosition=bottom;verticalAlign=top;align=center;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.simple_storage_service;" vertex="1" parent="1"><mxGeometry x="580" y="195" width="150" height="40" as="geometry"/></mxCell><mxCell id="c7" value="S3 gateway endpoint  (FREE)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE7F6;strokeColor=#8C4FFF;fontColor=#5e35b1;fontSize=11;dashed=0;fontStyle=0;arcSize=8;align=center;" vertex="1" parent="1"><mxGeometry x="580" y="195" width="150" height="40" as="geometry"/></mxCell><mxCell id="c8" value="Interface endpoints
ECR API + DKR, STS,
SSM, Secrets, CW Logs
~$0.01/hr/AZ + $0.01/GB" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE7F6;strokeColor=#8C4FFF;fontColor=#5e35b1;fontSize=11;dashed=0;fontStyle=0;arcSize=8;align=center;" vertex="1" parent="1"><mxGeometry x="745" y="195" width="160" height="90" as="geometry"/></mxCell><mxCell id="c9" value="AWS service APIs
S3, ECR, STS, Secrets Manager" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#D86613;fontColor=#232F3E;fontSize=11;dashed=0;fontStyle=1;arcSize=8;align=center;" vertex="1" parent="1"><mxGeometry x="1080" y="180" width="220" height="90" as="geometry"/></mxCell><mxCell id="c10" value="NAT Gateway
~$33/mo single  •  ~$98/mo per-AZ
+ $0.045/GB processed" style="sketch=0;points=[[0,0,0],[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0,0],[0,1,0],[0.25,1,0],[0.5,1,0],[0.75,1,0],[1,1,0],[0,0.25,0],[0,0.5,0],[0,0.75,0],[1,0.25,0],[1,0.5,0],[1,0.75,0]];outlineConnect=0;html=1;fontSize=11;fontStyle=0;aspect=fixed;shadow=0;dashed=0;fillColor=#7AA116;strokeColor=#ffffff;verticalLabelPosition=bottom;verticalAlign=top;align=center;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.nat_gateway;" vertex="1" parent="1"><mxGeometry x="620" y="430" width="200" height="90" as="geometry"/></mxCell><mxCell id="c11" value="" style="fillColor=none;strokeColor=none;" vertex="1" parent="1"><mxGeometry x="620" y="430" width="200" height="90" as="geometry"/></mxCell><mxCell id="c12" value="Internet
Gateway" style="sketch=0;points=[[0,0,0],[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0,0],[0,1,0],[0.25,1,0],[0.5,1,0],[0.75,1,0],[1,1,0],[0,0.25,0],[0,0.5,0],[0,0.75,0],[1,0.25,0],[1,0.5,0],[1,0.75,0]];outlineConnect=0;html=1;fontSize=11;fontStyle=0;aspect=fixed;shadow=0;dashed=0;fillColor=#8C4FFF;strokeColor=#ffffff;verticalLabelPosition=bottom;verticalAlign=top;align=center;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.internet_gateway;" vertex="1" parent="1"><mxGeometry x="900" y="440" width="140" height="70" as="geometry"/></mxCell><mxCell id="c13" value="Public internet
Twilio, SMTP relay, carrier APIs
(no VPC endpoint exists)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFEBEE;strokeColor=#C62828;fontColor=#232F3E;fontSize=11;dashed=0;fontStyle=1;arcSize=8;align=center;" vertex="1" parent="1"><mxGeometry x="1120" y="430" width="200" height="90" as="geometry"/></mxCell><mxCell id="c14" value="AWS APIs" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;fontSize=10;fontColor=#37474F;labelBackgroundColor=#ffffff;strokeWidth=1.6;strokeColor=#6A1B9A;" edge="1" parent="1" source="c3" target="c5"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="c15" value="private" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;fontSize=10;fontColor=#37474F;labelBackgroundColor=#ffffff;strokeWidth=1.6;strokeColor=#6A1B9A;dashed=1;" edge="1" parent="1" source="c5" target="c9"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="c16" value="third-party egress" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;fontSize=10;fontColor=#37474F;labelBackgroundColor=#ffffff;strokeWidth=1.6;strokeColor=#C62828;" edge="1" parent="1" source="c3" target="c10"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="c17" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;fontSize=10;fontColor=#37474F;labelBackgroundColor=#ffffff;strokeWidth=1.6;strokeColor=#C62828;" edge="1" parent="1" source="c10" target="c12"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="c18" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;fontSize=10;fontColor=#37474F;labelBackgroundColor=#ffffff;strokeWidth=1.6;strokeColor=#C62828;" edge="1" parent="1" source="c12" target="c13"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="c19" value="nat_mode  (one line in the module changes the whole egress model)" style="text;html=1;align=left;fontStyle=1;fontSize=13;fontColor=#232F3E;" vertex="1" parent="1"><mxGeometry x="120" y="600" width="1200" height="30" as="geometry"/></mxCell><mxCell id="c20" value="none

Zero NAT, private 0.0.0.0/0 routes vanish.
Pods reach S3 + ECR via endpoints, but
notification-service can't reach SMTP and
shipping-service can't reach carriers.
Cheapest, cannot do the job." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#90A4AE;fontColor=#37474F;fontSize=11;dashed=0;fontStyle=1;arcSize=8;align=center;" vertex="1" parent="1"><mxGeometry x="120" y="640" width="380" height="150" as="geometry"/></mxCell><mxCell id="c21" value="single   &lt;-- dev default

One NAT in one AZ (~$33/mo + data).
Other AZs route cross-AZ to it.
Not HA: lose that AZ, lose all egress.
Fine for dev. Name the risk for prod." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#7AA116;fontColor=#33691E;fontSize=11;dashed=0;fontStyle=1;arcSize=8;align=center;" vertex="1" parent="1"><mxGeometry x="520" y="640" width="380" height="150" as="geometry"/></mxCell><mxCell id="c22" value="per_az   &lt;-- prod

One NAT per AZ (~$98/mo + data).
Each AZ egresses locally, no cross-AZ hop.
Survives an AZ outage.
That is the +$65/mo HA line item." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1976D2;fontColor=#0D47A1;fontSize=11;dashed=0;fontStyle=1;arcSize=8;align=center;" vertex="1" parent="1"><mxGeometry x="920" y="640" width="380" height="150" as="geometry"/></mxCell><mxCell id="c23" value="The defensible answer for this project: single (dev) / per_az (prod) NAT for genuine third-party egress, PLUS the free S3 gateway endpoint and the ECR interface endpoints to take the heavy ECR + AWS-API traffic off NAT and keep it private. A wall of 8 interface endpoints (~$175/mo) costs more than a NAT, so add them with intent, not by reflex." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFF8E1;strokeColor=#FBC02D;fontColor=#5F4B00;fontSize=10;align=left;spacingLeft=6;shadow=0;" vertex="1" parent="1"><mxGeometry x="120" y="810" width="1200" height="60" as="geometry"/></mxCell></root></mxGraphModel></diagram><diagram name="EP3 - Security group layers" id="EP3_-_Security_group_layers"><mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1700" pageHeight="1100" math="0" shadow="0"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="c1" value="EP3: Security groups - cluster, node, pod, endpoints" style="text;html=1;align=left;verticalAlign=middle;fontColor=#232F3E;fontSize=20;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="40" y="20" width="900" height="34" as="geometry"/></mxCell><mxCell id="c2" value="Four layers, kept separate. A security group is a stateful allow-only firewall attached to an ENI." style="text;html=1;align=left;verticalAlign=middle;fontColor=#5A6B7B;fontSize=12;" vertex="1" parent="1"><mxGeometry x="40" y="54" width="1000" height="24" as="geometry"/></mxCell><mxCell id="c3" value="VPC  10.0.0.0/16" style="points=[[0,0],[0.25,0],[0.5,0],[0.75,0],[1,0],[1,0.25],[1,0.5],[1,0.75],[1,1],[0.75,1],[0.5,1],[0.25,1],[0,1],[0,0.75],[0,0.5],[0,0.25]];outlineConnect=0;gradientColor=none;html=1;whiteSpace=wrap;fillColor=none;strokeColor=#8C4FFF;dashed=0;verticalAlign=top;align=left;spacingLeft=30;fontColor=#8C4FFF;fontSize=12;fontStyle=1;container=0;collapsible=0;shape=mxgraph.aws4.group;grIcon=mxgraph.aws4.group_vpc;" vertex="1" parent="1"><mxGeometry x="60" y="120" width="1580" height="360" as="geometry"/></mxCell><mxCell id="c4" value="Cluster security group
EKS creates it automatically.
Attached to control-plane ENIs
and (by default) managed nodes.
Control plane &lt;-&gt; node traffic.
You mostly leave it alone." style="points=[[0,0],[0.25,0],[0.5,0],[0.75,0],[1,0],[1,0.25],[1,0.5],[1,0.75],[1,1],[0.75,1],[0.5,1],[0.25,1],[0,1],[0,0.75],[0,0.5],[0,0.25]];outlineConnect=0;gradientColor=none;html=1;whiteSpace=wrap;fillColor=none;strokeColor=#DD3522;dashed=1;verticalAlign=top;align=left;spacingLeft=30;fontColor=#DD3522;fontSize=12;fontStyle=1;container=0;collapsible=0;shape=mxgraph.aws4.group;grIcon=mxgraph.aws4.group_security_group;" vertex="1" parent="1"><mxGeometry x="120" y="180" width="320" height="130" as="geometry"/></mxCell><mxCell id="c5" value="Node security group
Attached to the EC2 instances.
Controls traffic to/from the nodes.
Where you allow NLB health
checks in, for example." style="points=[[0,0],[0.25,0],[0.5,0],[0.75,0],[1,0],[1,0.25],[1,0.5],[1,0.75],[1,1],[0.75,1],[0.5,1],[0.25,1],[0,1],[0,0.75],[0,0.5],[0,0.25]];outlineConnect=0;gradientColor=none;html=1;whiteSpace=wrap;fillColor=none;strokeColor=#DD3522;dashed=1;verticalAlign=top;align=left;spacingLeft=30;fontColor=#DD3522;fontSize=12;fontStyle=1;container=0;collapsible=0;shape=mxgraph.aws4.group;grIcon=mxgraph.aws4.group_security_group;" vertex="1" parent="1"><mxGeometry x="480" y="180" width="320" height="130" as="geometry"/></mxCell><mxCell id="c6" value="Pod security group  (opt-in)
SecurityGroupPolicy, backed by
the VPC CNI. Attaches a real SG
to a single pod, not the node.
For pod-level isolation
(e.g. only one pod reaches RDS)." style="points=[[0,0],[0.25,0],[0.5,0],[0.75,0],[1,0],[1,0.25],[1,0.5],[1,0.75],[1,1],[0.75,1],[0.5,1],[0.25,1],[0,1],[0,0.75],[0,0.5],[0,0.25]];outlineConnect=0;gradientColor=none;html=1;whiteSpace=wrap;fillColor=none;strokeColor=#DD3522;dashed=1;verticalAlign=top;align=left;spacingLeft=30;fontColor=#DD3522;fontSize=12;fontStyle=1;container=0;collapsible=0;shape=mxgraph.aws4.group;grIcon=mxgraph.aws4.group_security_group;" vertex="1" parent="1"><mxGeometry x="840" y="180" width="320" height="130" as="geometry"/></mxCell><mxCell id="c7" value="Endpoints security group  (this module)
Allows HTTPS 443 IN from the VPC CIDR
only, so pods can reach the interface
endpoints. Nothing else. Small,
single-purpose, easy to defend." style="points=[[0,0],[0.25,0],[0.5,0],[0.75,0],[1,0],[1,0.25],[1,0.5],[1,0.75],[1,1],[0.75,1],[0.5,1],[0.25,1],[0,1],[0,0.75],[0,0.5],[0,0.25]];outlineConnect=0;gradientColor=none;html=1;whiteSpace=wrap;fillColor=none;strokeColor=#2E7D32;dashed=0;verticalAlign=top;align=left;spacingLeft=30;fontColor=#2E7D32;fontSize=12;fontStyle=1;container=0;collapsible=0;shape=mxgraph.aws4.group;grIcon=mxgraph.aws4.group_security_group;" vertex="1" parent="1"><mxGeometry x="1200" y="180" width="380" height="130" as="geometry"/></mxCell><mxCell id="c8" value="Rule of thumb: cluster SG = control-plane chatter (leave it). node SG = host-level allow rules (NLB health checks). pod SG = surgical per-pod isolation, reach for it only when it genuinely matters. endpoints SG = 443 from the VPC CIDR and nothing more." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFF8E1;strokeColor=#FBC02D;fontColor=#5F4B00;fontSize=10;align=left;spacingLeft=6;shadow=0;" vertex="1" parent="1"><mxGeometry x="120" y="360" width="1460" height="90" as="geometry"/></mxCell><mxCell id="c9" value="Stateful: the SG remembers an outbound connection and auto-allows the return traffic, so you do not write a matching inbound rule for every reply." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8EAF6;strokeColor=#3F51B5;fontColor=#283593;fontSize=11;dashed=0;fontStyle=0;arcSize=8;align=center;" vertex="1" parent="1"><mxGeometry x="120" y="500" width="700" height="70" as="geometry"/></mxCell></root></mxGraphModel></diagram></mxfile>