e="sketch=0;outlineConnect=0;html=1;fontSize=11;fontStyle=0;aspect=fixed;shadow=0;dashed=0;fillColor=#7AA116;strokeColor=#ffffff;verticalLabelPosition=bottom;verticalAlign=top;align=center;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.nat_gateway;" vertex="1" parent="1"><mxGeometry x="350" y="664" width="120" height="72" as="geometry"/></mxCell><mxCell id="natlbl" value="egress 0.0.0.0/0 to the internet&amp;#10;the NAT decision is page 2" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#FFEBEE;strokeColor=#C62828;fontColor=#7a1f1f;fontSize=9;fontStyle=0;dashed=1;align=center;spacingLeft=0;shadow=0;" vertex="1" parent="1"><mxGeometry x="300" y="742" width="210" height="40" as="geometry"/></mxCell><mxCell id="s3" value="S3 Gateway VPC endpoint  (FREE, a route-table entry)  -  ECR image layers live in S3, so this carries the heaviest pull" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#EDE7F6;strokeColor=#8C4FFF;fontColor=#5e35b1;fontSize=11;fontStyle=1;dashed=0;align=center;spacingLeft=0;shadow=0;" vertex="1" parent="1"><mxGeometry x="90" y="1058" width="1420" height="52" as="geometry"/></mxCell><mxCell id="s3i" value="" style="sketch=0;outlineConnect=0;html=1;fontSize=11;fontStyle=0;aspect=fixed;shadow=0;dashed=0;fillColor=#7AA116;strokeColor=#ffffff;verticalLabelPosition=bottom;verticalAlign=top;align=center;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.simple_storage_service;" vertex="1" parent="1"><mxGeometry x="100" y="1062" width="40" height="40" as="geometry"/></mxCell><mxCell id="e1" value="ingress" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;jettySize=auto;orthogonalLoop=1;strokeWidth=1.8;fontSize=10;fontColor=#37474F;labelBackgroundColor=#ffffff;strokeColor=#2E7D32;dashed=0;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="usr" target="igw"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="740" y="185"/></Array></mxGeometry></mxCell><mxCell id="e2" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;jettySize=auto;orthogonalLoop=1;strokeWidth=1.8;fontSize=10;fontColor=#37474F;labelBackgroundColor=#ffffff;strokeColor=#2E7D32;dashed=0;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="igw" target="nlb"><mxGeometry relative="1" as="geometry"></mxGeometry></mxCell><mxCell id="e3a" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;jettySize=auto;orthogonalLoop=1;strokeWidth=1.8;fontSize=10;fontColor=#37474F;labelBackgroundColor=#ffffff;strokeColor=#2E7D32;dashed=0;exitX=0;exitY=0.3;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="nlb" target="nodea"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="85" y="526"/><mxPoint x="85" y="840"/></Array></mxGeometry></mxCell><mxCell id="e3b" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;jettySize=auto;orthogonalLoop=1;strokeWidth=1.8;fontSize=10;fontColor=#37474F;labelBackgroundColor=#ffffff;strokeColor=#2E7D32;dashed=0;exitX=0;exitY=0.7;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="nlb" target="nodeb"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="570" y="547"/><mxPoint x="570" y="840"/></Array></mxGeometry></mxCell><mxCell id="e3c" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;jettySize=auto;orthogonalLoop=1;strokeWidth=1.8;fontSize=10;fontColor=#37474F;labelBackgroundColor=#ffffff;strokeColor=#2E7D32;dashed=0;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="nlb" target="nodec"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="1050" y="536"/><mxPoint x="1050" y="840"/></Array></mxGeometry></mxCell><mxCell id="e4" value="private API via ENIs" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;jettySize=auto;orthogonalLoop=1;strokeWidth=1.8;fontSize=10;fontColor=#37474F;labelBackgroundColor=#ffffff;strokeColor=#D86613;dashed=1;exitX=0.4;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="cp" target="nodec"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="1300" y="780"/><mxPoint x="1195" y="780"/></Array></mxGeometry></mxCell></root></mxGraphModel></diagram><diagram name="EP3 - Egress: NAT vs VPC endpoints" id="EP3_p2"><mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1560" pageHeight="950" math="0" shadow="0"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="t1" value="EP3: the egress decision  (the line that earns the mark)" style="text;html=1;align=left;verticalAlign=middle;fontColor=#232F3E;fontSize=20;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="40" y="20" width="900" height="30" as="geometry"/></mxCell><mxCell id="t2" value="Two different things leave the VPC and take different roads. This is where cost, availability and privacy pull against each other." style="text;html=1;align=left;verticalAlign=middle;fontColor=#5A6B7B;fontSize=12;fontStyle=0;" vertex="1" parent="1"><mxGeometry x="40" y="52" width="1100" height="24" as="geometry"/></mxCell><mxCell id="pod" value="Pod in a private subnet&amp;#10;(needs to reach something&amp;#10;outside the VPC)" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#E0F7FA;strokeColor=#00A4A6;fontColor=#232F3E;fontSize=11;fontStyle=1;dashed=0;align=center;spacingLeft=0;shadow=0;" vertex="1" parent="1"><mxGeometry x="90" y="250" width="210" height="100" as="geometry"/></mxCell><mxCell id="podi" value="" style="sketch=0;outlineConnect=0;html=1;fontSize=11;fontStyle=0;aspect=fixed;shadow=0;dashed=0;fillColor=#E7157B;strokeColor=#ffffff;verticalLabelPosition=bottom;verticalAlign=top;align=center;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.ec2;" vertex="1" parent="1"><mxGeometry x="98" y="258" width="34" height="34" as="geometry"/></mxCell><mxCell id="epg" value="VPC Endpoints  (PrivateLink)&amp;#10;stays on the AWS backbone, never the internet" style="outlineConnect=0;gradientColor=none;html=1;whiteSpace=wrap;fillColor=none;strokeColor=#8C4FFF;dashed=1;verticalAlign=top;align=left;spacingLeft=30;fontColor=#8C4FFF;fontSize=12;fontStyle=1;container=0;collapsible=0;shape=mxgraph.aws4.group;grIcon=mxgraph.aws4.group_security_group;" vertex="1" parent="1"><mxGeometry x="440" y="140" width="420" height="150" as="geometry"/></mxCell><mxCell id="s3e" value="S3 gateway endpoint  (FREE)" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#EDE7F6;strokeColor=#8C4FFF;fontColor=#5e35b1;fontSize=11;fontStyle=0;dashed=0;align=center;spacingLeft=0;shadow=0;" vertex="1" parent="1"><mxGeometry x="460" y="190" width="160" height="46" as="geometry"/></mxCell><mxCell id="ife" value="Interface endpoints&amp;#10;ECR API+DKR, STS,&amp;#10;SSM, Secrets, CW Logs&amp;#10;~$0.01/hr/AZ + $0.01/GB" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#EDE7F6;strokeColor=#8C4FFF;fontColor=#5e35b1;fontSize=11;fontStyle=0;dashed=0;align=center;spacingLeft=0;shadow=0;" vertex="1" parent="1"><mxGeometry x="650" y="185" width="190" height="92" as="geometry"/></mxCell><mxCell id="apis" value="AWS service APIs&amp;#10;S3, ECR, STS, Secrets Manager" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#D86613;fontColor=#232F3E;fontSize=11;fontStyle=1;dashed=0;align=center;spacingLeft=0;shadow=0;" vertex="1" parent="1"><mxGeometry x="980" y="188" width="260" height="86" as="geometry"/></mxCell><mxCell id="nat" value="NAT Gateway&amp;#10;~$33/mo single  •  ~$98/mo per-AZ&amp;#10;+ $0.045/GB processed" style="sketch=0;outlineConnect=0;html=1;fontSize=11;fontStyle=0;aspect=fixed;shadow=0;dashed=0;fillColor=#7AA116;strokeColor=#ffffff;verticalLabelPosition=bottom;verticalAlign=top;align=center;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.nat_gateway;" vertex="1" parent="1"><mxGeometry x="470" y="430" width="210" height="90" as="geometry"/></mxCell><mxCell id="igw" value="Internet&amp;#10;Gateway" style="sketch=0;outlineConnect=0;html=1;fontSize=11;fontStyle=0;aspect=fixed;shadow=0;dashed=0;fillColor=#8C4FFF;strokeColor=#ffffff;verticalLabelPosition=bottom;verticalAlign=top;align=center;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.internet_gateway;" vertex="1" parent="1"><mxGeometry x="760" y="440" width="120" height="72" as="geometry"/></mxCell><mxCell id="net" value="Public internet&amp;#10;Twilio, SMTP relay, carrier APIs&amp;#10;(no VPC endpoint exists)" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#FFEBEE;strokeColor=#C62828;fontColor=#232F3E;fontSize=11;fontStyle=1;dashed=0;align=center;spacingLeft=0;shadow=0;" vertex="1" parent="1"><mxGeometry x="980" y="432" width="260" height="86" as="geometry"/></mxCell><mxCell id="h2" value="nat_mode  (one line in the module changes the whole egress model)" style="text;html=1;align=left;verticalAlign=middle;fontColor=#232F3E;fontSize=13;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="90" y="580" width="1200" height="28" as="geometry"/></mxCell><mxCell id="c_none" value="none&amp;#10;&amp;#10;Zero NAT, the private 0.0.0.0/0 routes vanish.&amp;#10;Pods still reach S3 and ECR via endpoints, but&amp;#10;notification-service cannot reach SMTP and&amp;#10;shipping-service cannot reach carriers.&amp;#10;Cheapest, cannot do the job." style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#90A4AE;fontColor=#37474F;fontSize=11;fontStyle=1;dashed=0;align=center;spacingLeft=0;shadow=0;" vertex="1" parent="1"><mxGeometry x="90" y="620" width="440" height="165" as="geometry"/></mxCell><mxCell id="c_single" value="single   &amp;lt;-- dev default&amp;#10;&amp;#10;One NAT in one AZ (~$33/mo + data).&amp;#10;Other AZs route cross-AZ to it.&amp;#10;Not HA: lose that AZ, lose all egress.&amp;#10;Fine for dev. Name the risk for prod." style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#7AA116;fontColor=#33691E;fontSize=11;fontStyle=1;dashed=0;align=center;spacingLeft=0;shadow=0;" vertex="1" parent="1"><mxGeometry x="560" y="620" width="440" height="165" as="geometry"/></mxCell><mxCell id="c_peraz" value="per_az   &amp;lt;-- prod&amp;#10;&amp;#10;One NAT per AZ (~$98/mo + data).&amp;#10;Each AZ egresses locally, no cross-AZ hop.&amp;#10;Survives an AZ outage.&amp;#10;That is the +$65/mo HA line item." style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1976D2;fontColor=#0D47A1;fontSize=11;fontStyle=1;dashed=0;align=center;spacingLeft=0;shadow=0;" vertex="1" parent="1"><mxGeometry x="1030" y="620" width="440" height="165" as="geometry"/></mxCell><mxCell id="verdict" value="The defensible answer for this project: single (dev) / per_az (prod) NAT for genuine third-party egress, PLUS the free S3 gateway endpoint and the ECR interface endpoints to take the heavy ECR and AWS-API traffic off NAT and keep it private. A wall of 8 interface endpoints (~$175/mo) costs more than a NAT, so add them with intent." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFF8E1;strokeColor=#FBC02D;fontColor=#5F4B00;fontSize=11;fontStyle=0;dashed=0;align=left;spacingLeft=6;shadow=0;" vertex="1" parent="1"><mxGeometry x="90" y="805" width="1380" height="70" as="geometry"/></mxCell><mxCell id="p1" value="AWS APIs" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;jettySize=auto;orthogonalLoop=1;strokeWidth=1.8;fontSize=10;fontColor=#37474F;labelBackgroundColor=#ffffff;strokeColor=#6A1B9A;dashed=0;exitX=1;exitY=0.4;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="pod" target="epg"><mxGeometry relative="1" as="geometry"></mxGeometry></mxCell><mxCell id="p2" value="private" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;jettySize=auto;orthogonalLoop=1;strokeWidth=1.8;fontSize=10;fontColor=#37474F;labelBackgroundColor=#ffffff;strokeColor=#6A1B9A;dashed=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="epg" target="apis"><mxGeometry relative="1" as="geometry"></mxGeometry></mxCell><mxCell id="p3" value="third-party egress" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;jettySize=auto;orthogonalLoop=1;strokeWidth=1.8;fontSize=10;fontColor=#37474F;labelBackgroundColor=#ffffff;strokeColor=#C62828;dashed=0;exitX=1;exitY=0.8;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="pod" target="nat"><mxGeometry relative="1" as="geometry"></mxGeometry></mxCell><mxCell id="p4" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;jettySize=auto;orthogonalLoop=1;strokeWidth=1.8;fontSize=10;fontColor=#37474F;labelBackgroundColor=#ffffff;strokeColor=#C62828;dashed=0;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="nat" target="igw"><mxGeometry relative="1" as="geometry"></mxGeometry></mxCell><mxCell id="p5" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;jettySize=auto;orthogonalLoop=1;strokeWidth=1.8;fontSize=10;fontColor=#37474F;labelBackgroundColor=#ffffff;strokeColor=#C62828;dashed=0;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="igw" target="net"><mxGeometry relative="1" as="geometry"></mxGeometry></mxCell></root></mxGraphModel></diagram><diagram name="EP3 - Security group layers" id="EP3_p3"><mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="760" math="0" shadow="0"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="t1" value="EP3: Security groups - cluster, node, pod, endpoints" style="text;html=1;align=left;verticalAlign=middle;fontColor=#232F3E;fontSize=20;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="40" y="20" width="900" height="30" as="geometry"/></mxCell><mxCell id="t2" value="Four layers, kept separate. A security group is a stateful allow-only firewall attached to an ENI." style="text;html=1;align=left;verticalAlign=middle;fontColor=#5A6B7B;fontSize=12;fontStyle=0;" vertex="1" parent="1"><mxGeometry x="40" y="52" width="1100" height="24" as="geometry"/></mxCell><mxCell id="cluster" value="Cluster security group&amp;#10;&amp;#10;EKS creates it automatically.&amp;#10;Attached to control-plane ENIs&amp;#10;and (by default) managed nodes.&amp;#10;Carries control plane &amp;lt;-&amp;gt; node traffic.&amp;#10;You mostly leave it alone." style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#FDECEA;strokeColor=#DD3522;fontColor=#9b2418;fontSize=11;fontStyle=0;dashed=1;align=center;spacingLeft=0;shadow=0;" vertex="1" parent="1"><mxGeometry x="60" y="150" width="340" height="180" as="geometry"/></mxCell><mxCell id="node" value="Node security group&amp;#10;&amp;#10;Attached to the EC2 instances.&amp;#10;Controls traffic to and from the nodes.&amp;#10;Where you allow NLB health&amp;#10;checks in, for example." style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#FDECEA;strokeColor=#DD3522;fontColor=#9b2418;fontSize=11;fontStyle=0;dashed=1;align=center;spacingLeft=0;shadow=0;" vertex="1" parent="1"><mxGeometry x="430" y="150" width="340" height="180" as="geometry"/></mxCell><mxCell id="pod" value="Pod security group  (opt-in)&amp;#10;&amp;#10;SecurityGroupPolicy, backed by&amp;#10;the VPC CNI. Attaches a real SG&amp;#10;to a single pod, not the node.&amp;#10;For pod-level isolation (e.g. only&amp;#10;one pod may reach a target)." style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#FDECEA;strokeColor=#DD3522;fontColor=#9b2418;fontSize=11;fontStyle=0;dashed=1;align=center;spacingLeft=0;shadow=0;" vertex="1" parent="1"><mxGeometry x="800" y="150" width="340" height="180" as="geometry"/></mxCell><mxCell id="eps" value="Endpoints security group  (this module)&amp;#10;&amp;#10;Allows HTTPS 443 IN from the VPC&amp;#10;CIDR only, so pods can reach the&amp;#10;interface endpoints. Nothing else.&amp;#10;Small, single-purpose, easy to defend." style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#2E7D32;fontColor=#1b5e20;fontSize=11;fontStyle=0;dashed=1;align=center;spacingLeft=0;shadow=0;" vertex="1" parent="1"><mxGeometry x="1170" y="150" width="360" height="180" as="geometry"/></mxCell><mxCell id="rot" value="Rule of thumb:  cluster SG = control-plane chatter (leave it).   node SG = host-level allow rules (NLB health checks).   pod SG = surgical per-pod isolation, reach for it only when it genuinely matters.   endpoints SG = 443 from the VPC CIDR and nothing more." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFF8E1;strokeColor=#FBC02D;fontColor=#5F4B00;fontSize=11;fontStyle=0;dashed=0;align=left;spacingLeft=6;shadow=0;" vertex="1" parent="1"><mxGeometry x="60" y="380" width="1470" height="90" as="geometry"/></mxCell><mxCell id="state" value="Stateful: the SG remembers an outbound connection and auto-allows the return traffic, so you do not write a matching inbound rule for every reply." style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#E8EAF6;strokeColor=#3F51B5;fontColor=#283593;fontSize=11;fontStyle=0;dashed=0;align=center;spacingLeft=0;shadow=0;" vertex="1" parent="1"><mxGeometry x="60" y="510" width="900" height="64" as="geometry"/></mxCell></root></mxGraphModel></diagram></mxfile>